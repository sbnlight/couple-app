# 复制本文件为 .env.local 并填入你自己 Supabase 项目的真实值
# (.env.local 已被 .gitignore 排除,绝不会提交)
# 取值位置:Supabase 控制台 → Project Settings → API Keys
VITE_SUPABASE_URL=https://你的项目id.supabase.co
VITE_SUPABASE_ANON_KEY=你的publishable公开密钥
# Web Push 的 VAPID 公钥(运行 node scripts/gen-vapid.cjs 生成自己的一对;
# 公钥填这里和部署平台,私钥只放 Supabase Edge Function Secrets)
VITE_VAPID_PUBLIC_KEY=你生成的VAPID公钥
